# Secrets Kestra — NE PAS COMMITTER ce fichier
# Copier en .env.secrets et remplir les valeurs réelles
# Usage : task secrets:set NAMESPACE=demo.finance

# UC1 - Exchange Rates API
EXCHANGE_API_KEY=your-api-key-here

# UC2 - File Processor
WEBHOOK_SECRET=your-webhook-secret-here

# UC3 - Notifications
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz
