# Kestra Core Configuration
# Copier ce fichier en .env.local à la racine du projet et adapter les valeurs

# --- Instance locale ---
KESTRA_URL=http://localhost:8080
KESTRA_USER=admin@kestra.io
KESTRA_PASSWORD=Kestr!!a123
KESTRA_PORT=8080

# --- Instance distante (deploy:remote) ---
KESTRA_REMOTE_URL=https://kestra.example.com
KESTRA_REMOTE_USER=admin@kestra.io
KESTRA_REMOTE_PASSWORD=

# --- SSH (deploy:remote via tunnel) ---
SSH_HOST=kestra.example.com
SSH_USER=ubuntu
SSH_KEY_PATH=~/.ssh/id_rsa
